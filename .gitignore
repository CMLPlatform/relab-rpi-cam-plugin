#.gitignore for Relab RPi Cam Plugin API
## Python
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Unit test / coverage reports
htmlcov/
.coverage
.coverage.*
.cache
coverage.xml
coverage.json
*.cover
.hypothesis/
.pytest_cache/
cover/

# Environments
.env
.venv

# Ruff linter
.ruff_cache/


### Manual additions
# Allow example env file
!.env.example

# Captured images
data/images/

# VS Code settings
!.vscode/settings.json
!.vscode/extensions.json

# Logs
logs/

# The compose override stores machine-specific device mappings
compose.override.yml

# Websocket connection credentials
**/relay_credentials.json
