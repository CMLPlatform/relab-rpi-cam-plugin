# Environment template for the RPi camera plugin.
# Copy to ``.env`` and uncomment/edit what you need. Everything is optional
# except ``RUSTFS_SECRET_KEY`` if you run the ``standalone`` compose profile.

# ─── Local API auth ──────────────────────────────────────────────────────────
# API keys accepted for ``X-API-Key`` authentication on the local web UI.
# NOT needed for the Relab relay — that uses a device JWT generated at
# pairing time. Dotenv arrays need single quotes to be parsed correctly.
# AUTHORIZED_API_KEYS='["CHANGE_ME"]'

# Override if the Pi is reachable at a different address.
# BASE_URL='http://127.0.0.1:8018'

# Extra CORS origins (defaults include localhost:8000 and cml-relab.org).
# ALLOWED_CORS_ORIGINS='["http://127.0.0.1:8000", "https://cml-relab.org"]'

# Camera device number (default 0).
# CAMERA_DEVICE_NUM=0

# ─── Relab backend pairing (paired mode, default) ────────────────────────────
# Point at the Relab platform API to enable automatic pairing. Once paired,
# captures are pushed to the backend via the device JWT. If the plugin runs
# in Docker and the Relab backend runs on the same host, use
# ``http://host.docker.internal:8011`` instead of ``http://localhost:8011``.
# PAIRING_BACKEND_URL=https://api.cml-relab.org

# ─── Standalone mode (no Relab backend) ──────────────────────────────────────
# To run without a Relab backend, enable the ``standalone`` compose profile
# (``docker compose --profile standalone up -d``) and configure the plugin
# to write captures directly to the bundled RustFS sidecar instead of the
# backend. Leave ``PAIRING_BACKEND_URL`` empty in this mode.
#
# IMAGE_SINK=s3
# S3_ENDPOINT_URL=http://host.docker.internal:9000
# S3_BUCKET=rpi-cam
# S3_ACCESS_KEY_ID=${RUSTFS_ACCESS_KEY:-rustfsadmin}
# S3_SECRET_ACCESS_KEY=${RUSTFS_SECRET_KEY}
# S3_REGION=us-east-1
# Template for the public URL returned to the frontend. Variables: {endpoint},
# {bucket}, {key}. Default path-style works for RustFS and generic S3. For a
# CDN-fronted bucket (R2 custom domain, CloudFront, etc.), override with e.g.
# ``https://cdn.example.com/{key}``.
# S3_PUBLIC_URL_TEMPLATE={endpoint}/{bucket}/{key}
#
# RustFS admin credentials used by the sidecar and shown on the :9001 console.
# RUSTFS_SECRET_KEY is REQUIRED when the ``standalone`` profile is active —
# compose refuses to start without it.
# RUSTFS_ACCESS_KEY=rustfsadmin
# RUSTFS_SECRET_KEY=change-me-to-a-strong-password

# ─── Remote observability (optional, profile: observability-ship) ────────────
# Ship structured logs to a Loki-compatible endpoint.
# LOKI_PUSH_URL=http://your-observability-host:3100/loki/api/v1/push
#
# Ship metrics to a Prometheus remote_write receiver (Mimir, Grafana Cloud,
# VictoriaMetrics, etc). Leave unset to ship logs only. The ``/metrics``
# endpoint on the Pi is always exposed on the trusted docker network whether
# or not this is set.
# PROMETHEUS_REMOTE_WRITE_URL=http://your-observability-host:9090/api/v1/write
#
# Unique label to identify this Pi in central observability.
# OBSERVABILITY_INSTANCE=pi-01
