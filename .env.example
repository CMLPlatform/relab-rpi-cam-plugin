# Example of the .env file for the Raspberry Pi Camera API
### Required settings ###
# Network address of the Raspberry Pi Camera API
BASE_URL='http://127.0.0.1:8018'

# API Keys generated on the main API. Note that each key must be enclosed in double quotes.
AUTHORIZED_API_KEYS=["CHANGE_ME", "AND_ME_AS_WELL"]

### Optional settings ###
# Add the network address of the main API. Add additional addresses if needed. Note that each address must be enclosed in double quotes.
ALLOWED_CORS_ORIGINS=["http://127.0.0.1:8000", "https://cml-relab.org", "https://api.cml-relab.org"]

# Camera device number (usually 0 or 1)
CAMERA_DEVICE_NUM=0

# Cloudflare Tunnel token (optional, only if using Cloudflare Tunnel)
TUNNEL_TOKEN='your_cloudflare_tunnel_token_here'
