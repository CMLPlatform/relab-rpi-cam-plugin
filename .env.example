# Required: API keys from the main RELab platform (JSON list).
# Note that dotenv arrays need to wrapped in single quotes to be parsed correctly.
AUTHORIZED_API_KEYS='["CHANGE_ME"]'

# Optional: override if the Pi is reachable at a different address
# BASE_URL='http://127.0.0.1:8018'

# Optional: enable automatic pairing by pointing at the platform API.
# If the plugin runs in Docker and the RELab backend runs on your host machine,
# use http://host.docker.internal:8011 rather than http://localhost:8011.
# PAIRING_BACKEND_URL=https://api.cml-relab.org

# Optional: additional CORS origins (defaults include localhost:8000 and cml-relab.org)
# ALLOWED_CORS_ORIGINS='["http://127.0.0.1:8000", "https://cml-relab.org"]'

# Optional: camera device number (default 0)
# CAMERA_DEVICE_NUM=0

# Optional: Cloudflare Tunnel token
# TUNNEL_TOKEN=

# Required when enabling the observability shipper profile.
# LOKI_PUSH_URL=http://your-observability-host:3100/loki/api/v1/push

# Optional: unique label to identify this Pi in central observability.
# Examples: pi-01, studio-west, bench-cam-2
# OBSERVABILITY_INSTANCE=rpi-cam-plugin
