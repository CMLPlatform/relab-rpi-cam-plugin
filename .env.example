# Required: API keys from the main RELab platform (JSON list)
AUTHORIZED_API_KEYS=["CHANGE_ME"]

# Optional: override if the Pi is reachable at a different address
# BASE_URL='http://127.0.0.1:8018'

# Optional: additional CORS origins (defaults include localhost:8000 and cml-relab.org)
# ALLOWED_CORS_ORIGINS=["http://127.0.0.1:8000", "https://cml-relab.org"]

# Optional: camera device number (default 0)
# CAMERA_DEVICE_NUM=0

# Optional: Cloudflare Tunnel token
# TUNNEL_TOKEN=
