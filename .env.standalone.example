# Standalone-mode environment template. Copy to ``.env.standalone`` and
# adjust for your deployment, then:
#
#     docker compose -f docker-compose.standalone.yml --env-file .env.standalone up -d
#
# At minimum you MUST set ``MINIO_ROOT_PASSWORD`` — the compose file will
# refuse to start otherwise. Everything else has sensible defaults.

# ─── API auth ────────────────────────────────────────────────────────────────
# Keys the camera API accepts for ``X-API-Key`` authentication. Space-separate
# multiple keys. Generate with ``openssl rand -hex 32`` or similar.
AUTHORIZED_API_KEYS=change-me-to-a-random-token

# ─── Image sink ──────────────────────────────────────────────────────────────
# ``s3`` points the plugin at the MinIO sidecar. The ``standalone`` compose
# builds the Docker image with the ``[s3]`` extra so ``aioboto3`` is present.
IMAGE_SINK=s3

# S3 credentials. In standalone mode these point at the MinIO sidecar on the
# same host network (``host.docker.internal:9000`` from inside the app
# container). If you front MinIO with a reverse proxy, update S3_ENDPOINT_URL
# and S3_PUBLIC_URL_TEMPLATE accordingly.
S3_ENDPOINT_URL=http://host.docker.internal:9000
S3_BUCKET=rpi-cam
S3_ACCESS_KEY_ID=${MINIO_ROOT_USER:-minioadmin}
S3_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
S3_REGION=us-east-1
# URL template for the public URL the plugin returns to the frontend.
# Variables: {endpoint}, {bucket}, {key}. Default path-style works for MinIO.
# For a CDN-fronted bucket (R2 custom domain, CloudFront, etc.) set something
# like: S3_PUBLIC_URL_TEMPLATE=https://cdn.example.com/{key}
S3_PUBLIC_URL_TEMPLATE={endpoint}/{bucket}/{key}

# ─── MinIO sidecar root credentials ──────────────────────────────────────────
# These are the MinIO admin account used to create the bucket and shown in the
# MinIO console at http://<pi>:9001. ``MINIO_ROOT_PASSWORD`` MUST be set —
# docker compose will refuse to start without it.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-to-a-strong-password
