loki.source.file "app_logs" {
  targets = [
    {
      __path__ = "/var/log/app/*.log",
    },
  ]
  forward_to = [loki.process.app.receiver]

  file_match {
    enabled     = true
    sync_period = "10s"
  }
}

loki.process "app" {
  stage.json {
    expressions = {
      level     = "level",
      timestamp = "timestamp",
    }
  }

  stage.timestamp {
    source = "timestamp"
    format = "RFC3339"
  }

  stage.static_labels {
    values = {
      job      = "rpi-cam-plugin",
      instance = sys.env("OBSERVABILITY_INSTANCE"),
    }
  }

  stage.labels {
    values = {
      level = "",
    }
  }

  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  endpoint {
    url = sys.env("LOKI_PUSH_URL")
  }
}
